DEEPSEEK_API_KEY=
# Optional: lets the AI research assistant search the web for facts not in the
# stored property data (neighborhood, schools, local market). Geocoding tools
# work without any key.
BRAVE_API_KEY=
# Optional: live mortgage-rate anchor for the calculator, from the St. Louis Fed
# FRED API (Freddie Mac weekly averages). Free key: https://fred.stlouisfed.org/docs/api/api_key.html
# Without it, the calculator uses a static national-average anchor.
FRED_API_KEY=
